# ============================================================================
# Lighthouse Platform — Environment Variables
# Copy this file to .env.local and fill in values.
# ============================================================================

# Supabase — create project at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Anthropic — for SHIELD AI photo analysis + PILOT chat
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — for subscriptions, one-time purchases, customer portal
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — for transactional email (assessment delivery, course completion, etc.)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Lighthouse Protection Group <noreply@lighthouseprotection.group>

# App URL (for callbacks, OG, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
